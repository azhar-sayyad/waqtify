{
  "compilerOptions": {
    "strict": true,
    "module": "Preserve",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@waqtify/types": ["../types/src"]
    }
  },
  "include": ["src"]
}
